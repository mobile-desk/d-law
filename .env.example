DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production (Render, Railway, etc.): set your public URL(s), comma-separated.
# DJANGO_ALLOWED_HOSTS=your-app.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# PostgreSQL in production — leave unset locally to use SQLite (db.sqlite3).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Groq — https://console.groq.com/keys (key starts with gsk_)
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.1-8b-instant
